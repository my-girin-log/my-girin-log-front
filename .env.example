# Set to "true" to call the real backend (Spring Boot) via Vite proxy.
# Leave unset or "false" to use the in-browser mockApi (default).
VITE_USE_REAL_API=false

# Backend origin proxied by Vite at /api when VITE_USE_REAL_API=true.
# Defaults to http://localhost:8080 for local Spring Boot dev.
VITE_BACKEND_URL=http://localhost:8080

# Optional: override API base path. Defaults to /api/v1 (matches backend).
# VITE_API_BASE_URL=/api/v1
