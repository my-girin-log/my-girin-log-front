# Set to "true" to call the real backend (Spring Boot) via Vite proxy.
# Leave unset or "false" to use the in-browser mockApi (default).
VITE_USE_REAL_API=false

# Backend origin proxied by Vite at /api when VITE_USE_REAL_API=true.
# Defaults to http://localhost:8080 for local Spring Boot dev.
VITE_BACKEND_URL=http://localhost:8080

# Optional: override API base path. Defaults to /api/v1 (matches backend).
# VITE_API_BASE_URL=/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# 배포된 백엔드(Render 등) 호출하기
# ─────────────────────────────────────────────────────────────────────────────
# 백엔드가 https://my-grin-log-back.onrender.com 에 배포돼 있음.
# 첫 호출은 15분 idle 후 sleep 때문에 ~50초 걸릴 수 있음 (그 다음은 정상).
#
# (1) 로컬 dev 에서 Render 백엔드 사용:
#     .env.development.local 에 ↓
#       VITE_USE_REAL_API=true
#       VITE_BACKEND_URL=https://my-grin-log-back.onrender.com
#
# (2) 프로덕션 빌드 (Vercel/Netlify 등):
#     vite proxy 가 안 먹으므로 VITE_API_BASE_URL 로 절대 URL 박아야 함.
#     플랫폼의 환경변수 설정에 ↓
#       VITE_USE_REAL_API=true
#       VITE_API_BASE_URL=https://my-grin-log-back.onrender.com/api/v1
#
# 백엔드 CORS 에 프론트 도메인이 등록돼 있어야 함:
#   - dev: http://localhost:5173, http://127.0.0.1:5173 (이미 허용)
#   - prod: 본인 vercel.app/netlify.app 도메인 → 백엔드 팀에 알리거나
#           Render dashboard 의 CORS_ALLOWED_ORIGIN_PATTERNS 에 https://*.vercel.app 추가
